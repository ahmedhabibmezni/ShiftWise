# ShiftWise Backend Configuration Template
# Copiez ce fichier en .env et remplissez les valeurs

# Application
APP_NAME=ShiftWise
APP_VERSION=1.0.0
# DEBUG=False en production. En dev local, surcharger à True dans .env si besoin.
DEBUG=False

# Database PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=shiftwise_db
DATABASE_USER=postgres
DATABASE_PASSWORD=VOTRE_MOT_DE_PASSE_ICI

# Database Pool Configuration
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Security & JWT
SECRET_KEY=GENEREZ_UNE_CLE_SECRETE_ICI
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Credential vault (Fernet) — chiffre les credentials hyperviseurs au repos.
# Obligatoire : générer avec
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Pour la rotation, ajouter l'ancienne clé dans SHIFTWISE_FERNET_OLD_KEYS
# (séparées par des virgules) avant de retirer la primary.
SHIFTWISE_FERNET_KEY=GENEREZ_UNE_FERNET_KEY_ICI
SHIFTWISE_FERNET_OLD_KEYS=

# Refresh token cookie
# REFRESH_COOKIE_SECURE=True par défaut (cookie émis sur HTTPS uniquement).
# Ne le passer à False QUE pour du dev local non-HTTPS (http://localhost).
# COOKIE_DOMAIN vide en dev (host=localhost). En prod, remplir avec le
# registrable domain partagé (ex. ".migration.nextstep-it.com").
REFRESH_COOKIE_NAME=shiftwise_refresh
REFRESH_COOKIE_PATH=/api/v1/auth
REFRESH_COOKIE_SAMESITE=strict
REFRESH_COOKIE_SECURE=True
# REFRESH_COOKIE_DOMAIN=.migration.nextstep-it.com

# Redis (auth store + Celery broker)
REDIS_AUTH_URL=redis://localhost:6379/1

# CORS (Frontend URLs allowed)
BACKEND_CORS_ORIGINS=["http://localhost:5173"]

# API Settings
API_V1_PREFIX=/api/v1

# ============================================
# SSH (connecteurs hyperviseurs KVM / Proxmox)
# ============================================
# KVM_SSH_KEY_PATH : chemin de la clé privée SSH du connecteur KVM.
# Vide => paramiko utilise l'agent / ~/.ssh.
# KVM_SSH_KEY_PATH=
# SSH_KEY_ALLOWED_ROOT : racine autorisée pour tout ssh_key_path fourni
# dans connection_config (audit A5 — anti path-traversal). Vide => aucune
# restriction de racine (le chemin doit rester absolu et sans '..').
SSH_KEY_ALLOWED_ROOT=/etc/shiftwise/ssh

# ============================================
# KUBERNETES / OPENSHIFT CONFIGURATION
# ============================================

# MODE 1: Kubeconfig File (Développement local)
# Chemin vers le fichier kubeconfig
KUBECONFIG_PATH=./config/kubeconfig

# MODE 2: In-Cluster Config (Production dans OpenShift)
# Si USE_IN_CLUSTER=true, ignore KUBECONFIG_PATH et utilise le ServiceAccount du pod
USE_IN_CLUSTER=false

# MODE 3: Custom Connection (Production externe - Optionnel)
# Si défini, utilise ces credentials au lieu de kubeconfig
# KUBERNETES_API_URL=https://api.migration.nextstep-it.com:6443
# KUBERNETES_TOKEN=your-service-account-token-here
# KUBERNETES_VERIFY_SSL=false

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL